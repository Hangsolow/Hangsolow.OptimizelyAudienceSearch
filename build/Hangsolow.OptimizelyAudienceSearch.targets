<Project>
  <!--
    This targets file is automatically imported by consuming projects via NuGet conventions.
    It copies the Optimizely shell module ZIP into the consuming project's source directory
    so the CMS can resolve and serve the module at runtime from modules/_protected/.
  -->
  <Target Name="CopyHangsolowAudienceSearchModule" BeforeTargets="Build"
          Condition="'$(PackageId)' != 'Hangsolow.OptimizelyAudienceSearch'">
    <Copy SourceFiles="$(MSBuildThisFileDirectory)..\contentFiles\any\any\modules\_protected\Hangsolow.OptimizelyAudienceSearch\Hangsolow.OptimizelyAudienceSearch.zip"
          DestinationFolder="$(MSBuildProjectDirectory)\modules\_protected\Hangsolow.OptimizelyAudienceSearch\"
          SkipUnchangedFiles="true" />
  </Target>
</Project>
